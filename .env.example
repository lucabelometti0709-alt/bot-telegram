TELEGRAM_BOT_TOKEN=il_tuo_token_qui
TELEGRAM_CHAT_ID=il_tuo_chat_id_qui
DATABASE_URL=
# Fuso orario: usa il formato TZ (es: Europe/Rome per UTC+2, Europe/London per UTC+1)
# Lascia vuoto per usare il fuso orario del sistema
TIMEZONE=Europe/Rome
# Ora del messaggio giornaliero (HH:MM formato 24h)
DAILY_MESSAGE_HOUR=8
DAILY_MESSAGE_MINUTE=0
# Minuti prima dell'attività per il promemoria
REMINDER_MINUTES_BEFORE=5
# Minuti DOPO l'orario programmato per eliminare automaticamente il task
# Es: 1 = elimina 1 minuto dopo l'orario, 60 = elimina 1 ora dopo, 0 = disabilita
AUTO_DELETE_MINUTES_AFTER=1
